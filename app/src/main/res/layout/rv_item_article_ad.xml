<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_press_color_surface"
    android:padding="16dp">

    <com.google.android.gms.ads.nativead.NativeAdView
        android:id="@+id/ad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:id="@+id/rl_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/ll_new"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_alignTop="@+id/ad_advertiser"
                    android:layout_alignBottom="@+id/ad_advertiser"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_new"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:text="@string/tag_new"
                        android:textColor="?colorTextMain"
                        android:textSize="@dimen/text_notes" />

                </LinearLayout>

                <TextView
                    android:id="@+id/ad_advertiser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="5dp"
                    android:layout_toEndOf="@+id/ll_new"
                    android:textColor="@color/selector_text_color_article_author"
                    android:textSize="@dimen/text_notes" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@+id/ad_advertiser"
                    android:layout_alignBottom="@+id/ad_advertiser"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@+id/ad_advertiser"
                    android:background="@drawable/selector_article_tag_bg"
                    android:gravity="center"
                    android:paddingStart="3dp"
                    android:paddingEnd="3dp"
                    android:text="@string/ad"
                    android:textColor="@color/selector_text_color_article_tag"
                    android:textSize="@dimen/text_time" />

            </RelativeLayout>

            <LinearLayout
                android:id="@+id/ll_middle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/rl_top"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.gms.ads.nativead.MediaView
                    android:id="@+id/ad_media"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"
                        android:maxLines="3"
                        android:singleLine="false"
                        android:textColor="?colorTextSurface"
                        android:textSize="@dimen/text_content"
                        tools:singleLine="true"
                        tools:text="@tools:sample/full_names" />

                    <TextView
                        android:id="@+id/ad_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:ellipsize="end"
                        android:includeFontPadding="true"
                        android:lineSpacingExtra="0dp"
                        android:maxLines="4"
                        android:textColor="?colorTextSecond"
                        android:textSize="@dimen/text_auxiliary"
                        android:visibility="gone"
                        tools:text="@tools:sample/lorem/random"
                        tools:visibility="visible" />

                    <RatingBar
                        android:id="@+id/ad_stars"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:stepSize="0.5" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/ll_middle"
                android:layout_centerVertical="true"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:text="@string/tag_top"
                    android:textColor="?colorTextAccent"
                    android:textSize="@dimen/text_notes" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_chapter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/ll_middle"
                android:layout_marginTop="10dp"
                android:layout_toEndOf="@+id/ll_top"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/ad_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:textColor="?colorTextAccent"
                    android:textSize="@dimen/text_notes" />

                <TextView
                    android:id="@+id/ad_store"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/selector_text_color_article_chapter"
                    android:textSize="@dimen/text_notes" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ad_call_to_action"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignBottom="@+id/ll_chapter"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_download"
                android:tint="?attr/colorTextAccent" />

            <!--        <per.goweii.wanandroid.widget.SubmitView-->
            <!--            android:id="@+id/ad_call_to_action"-->
            <!--            style="@style/ButtonMain"-->
            <!--            android:layout_width="wrap_content"-->
            <!--            android:layout_height="wrap_content"-->
            <!--            android:layout_alignBottom="@+id/ll_chapter"-->
            <!--            android:layout_alignParentEnd="true"-->
            <!--            android:paddingStart="16dp"-->
            <!--            android:paddingTop="8dp"-->
            <!--            android:paddingEnd="16dp"-->
            <!--            android:paddingBottom="8dp" />-->

        </RelativeLayout>
    </com.google.android.gms.ads.nativead.NativeAdView>

</FrameLayout>